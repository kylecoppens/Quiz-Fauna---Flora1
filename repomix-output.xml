                cat = "trees"
            elif any(x in species for x in ["Taraxacum", "Bellis", "Achillea", "Plantago", "Urtica"]):
                cat = "flora"
            elif any(x in species for x in ["Amanita", "Boletus", "Cantharellus", "Agaricus", "Pleurotus"]):
                cat = "fungi"
            
            # Mapping common names if available from title
