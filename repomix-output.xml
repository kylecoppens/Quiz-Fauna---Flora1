                    <button class="sub-tab" data-subfilter="trees_conifer">🌲 Naaldbomen</button>
                    <button class="sub-tab" data-subfilter="trees_deciduous">🍂 Loofbomen</button>
                </div>
            </div>

            <!-- ── PHYLOGENY BANNER — navigates to screen-phylo in-app ────────────── -->
            <div class="phylo-banner">
