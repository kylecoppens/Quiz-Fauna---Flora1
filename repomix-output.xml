                    <button class="sub-tab" data-subfilter="birds_raptor">🦅 Roofvogels</button>
                    <button class="sub-tab" data-subfilter="birds_water">🦆 Watervogels</button>
                    <button class="sub-tab" data-subfilter="birds_dove">🕊️ Duiven &amp; Uilen</button>
                    <button class="sub-tab" data-subfilter="birds_other">🐦 Overige</button>
                </div>

