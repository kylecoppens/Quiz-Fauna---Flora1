        <!-- ══ PHYLOGENY SCREEN ══════════════════════════════════════════ -->
        <section id="screen-phylo" class="screen hidden phylo-screen">
            <div class="phylo-screen-topbar">
                <button class="btn-back-phylo back-btn" data-target="screen-learn">← Encyclopedie</button>
                <h2>🌳 Fylogenetische boom</h2>
                <div class="phylo-sp-count" id="phylo-sp-count"></div>
            </div>

            <div class="phylo-filter-bar" id="phylo-filter-bar">
                <button class="phylo-chip active" data-g="all">🌍 Alles</button>
                <button class="phylo-chip" data-g="fauna">🦊 Zoogdieren</button>
                <button class="phylo-chip" data-g="birds">🐦 Vogels</button>
                <button class="phylo-chip" data-g="insects">🦋 Insecten</button>
                <button class="phylo-chip" data-g="flora">🌸 Flora</button>
                <button class="phylo-chip" data-g="fungi">🍄 Fungi</button>
                <button class="phylo-chip" data-g="trees">🌲 Bomen</button>
                <button class="phylo-chip" data-g="agriculture">🌾 Gekweekt</button>
                <div class="phylo-search-wrap">
                    <input class="phylo-search-input" id="phylo-search" type="text" placeholder="Zoek soort…">
                </div>
            </div>

            <div class="phylo-legend">
                <span class="phylo-leg"><span class="phylo-leg-dot" style="background:#3db863"></span>Zoogdieren</span>
                <span class="phylo-leg"><span class="phylo-leg-dot" style="background:#56c4e8"></span>Vogels</span>
                <span class="phylo-leg"><span class="phylo-leg-dot" style="background:#f0c05a"></span>Insecten</span>
                <span class="phylo-leg"><span class="phylo-leg-dot" style="background:#7ec860"></span>Dicotylen</span>
                <span class="phylo-leg"><span class="phylo-leg-dot" style="background:#f0c05a;border:1px dashed #c89030"></span>Monocotylen</span>
                <span class="phylo-leg"><span class="phylo-leg-dot" style="background:#c87ef0"></span>Fungi</span>
