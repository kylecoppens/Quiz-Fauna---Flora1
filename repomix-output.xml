<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fylogenie — Belgische Fauna &amp; Flora</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0c1410;--surface:#131f17;--card:#192318;--border:rgba(255,255,255,.07);
  --border2:rgba(255,255,255,.12);--green:#3db863;--gold:#f0c05a;--blue:#56c4e8;
  --purple:#b07ee8;--text:#e8f0ea;--muted:#7a9980;--faint:rgba(255,255,255,.04);
  --font-h:'Outfit',sans-serif;--font-b:'Inter',sans-serif;--r:10px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--font-b);font-size:14px;min-height:100vh}

/* TOPBAR */
.topbar{display:flex;align-items:center;gap:16px;padding:14px 24px;background:rgba(0,0,0,.45);
  border-bottom:1px solid var(--border2);backdrop-filter:blur(16px);position:sticky;top:0;z-index:200}
.back-btn{display:flex;align-items:center;gap:6px;color:var(--green);text-decoration:none;
  font-family:var(--font-h);font-weight:700;font-size:13px;padding:6px 14px;border:1px solid var(--green);
  border-radius:20px;transition:background .2s;cursor:pointer;background:transparent}
.back-btn:hover{background:rgba(61,184,99,.14)}
.topbar-title{font-family:var(--font-h);font-weight:700;font-size:1.15rem}
.topbar-sub{font-size:12px;color:var(--muted);margin-top:1px}
.isolate-notice{margin-left:auto;display:none;align-items:center;gap:10px;
  background:rgba(240,192,90,.12);border:1px solid rgba(240,192,90,.3);border-radius:8px;
  padding:6px 14px;font-size:12px;color:var(--gold);font-weight:600}
.isolate-notice.visible{display:flex}
.reset-btn{background:var(--gold);color:#000;border:none;border-radius:6px;padding:3px 10px;
  font-size:11px;font-weight:700;cursor:pointer;transition:opacity .2s}
.reset-btn:hover{opacity:.85}

/* FILTER BAR */
.filter-bar{display:flex;align-items:center;gap:8px;flex-wrap:wrap;padding:12px 24px;
  border-bottom:1px solid var(--border);background:var(--surface)}
.filter-label{font-size:11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.8px;margin-right:4px}
.filt-btn{display:flex;align-items:center;gap:5px;background:transparent;border:1px solid var(--border2);
  color:var(--muted);font-family:var(--font-h);font-weight:600;font-size:12px;padding:5px 13px;
  border-radius:16px;cursor:pointer;transition:all .2s}
.filt-btn:hover{border-color:var(--green);color:var(--text)}
.filt-btn.active{background:rgba(61,184,99,.16);border-color:var(--green);color:var(--green)}
.search-box{margin-left:auto;background:var(--card);border:1px solid var(--border2);color:var(--text);
  font-family:var(--font-b);font-size:13px;padding:6px 14px;border-radius:16px;width:200px;outline:none;transition:border-color .2s}
.search-box:focus{border-color:var(--green)}
.search-box::placeholder{color:var(--muted)}

/* STATS */
.stats-bar{padding:8px 24px;font-size:12px;color:var(--muted);background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;gap:4px}
.stats-bar b{color:var(--green)}

/* SCROLL */
.tree-scroll{padding:28px 24px 80px}

/* KINGDOM */
.kingdom-block{margin-bottom:28px;border:1px solid var(--border2);border-radius:var(--r);overflow:hidden;transition:opacity .35s}
.kingdom-block.dimmed{opacity:.15;pointer-events:none}
.kingdom-header{display:flex;align-items:center;gap:12px;padding:14px 20px;cursor:pointer;user-select:none;transition:background .2s}
.kingdom-header:hover{background:var(--faint)}
.kh-icon{font-size:1.5rem}
.kh-name{font-family:var(--font-h);font-weight:900;font-size:1.1rem}
.kh-sci{font-style:italic;font-size:12px;color:var(--muted)}
.kh-count{margin-left:auto;font-size:12px;color:var(--muted);background:var(--faint);border:1px solid var(--border2);padding:2px 10px;border-radius:10px}
.kh-toggle{font-size:13px;color:var(--muted);transition:transform .25s}
.kingdom-block.collapsed .kh-toggle{transform:rotate(-90deg)}
.kingdom-body{padding:0 16px 16px;display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:12px;border-top:1px solid var(--border)}
.kingdom-block.collapsed .kingdom-body{display:none}

/* CLASS CARD */
.class-card{background:var(--card);border:1px solid var(--border2);border-radius:var(--r);overflow:hidden;transition:opacity .35s,border-color .2s}
.class-card.dimmed{opacity:.12;pointer-events:none}
.class-card.focused{border-color:var(--green);box-shadow:0 0 0 1px rgba(61,184,99,.3)}
.class-header{display:flex;align-items:center;gap:8px;padding:10px 14px;cursor:pointer;user-select:none;transition:background .2s;border-radius:var(--r) var(--r) 0 0}
.class-header:hover{background:rgba(255,255,255,.04)}
.class-header.is-focused{background:rgba(61,184,99,.08)}
.ch-icon{font-size:1.1rem}
.ch-name{font-family:var(--font-h);font-weight:700;font-size:.88rem}
.ch-sci{font-style:italic;font-size:11px;color:var(--muted)}
.ch-count{margin-left:auto;font-size:11px;color:var(--muted);background:rgba(255,255,255,.05);border:1px solid var(--border);padding:1px 8px;border-radius:8px}
.ch-arrow{font-size:11px;color:var(--muted);transition:transform .2s}
.class-card.collapsed .ch-arrow{transform:rotate(-90deg)}
.class-body{padding:0 10px 10px}
.class-card.collapsed .class-body{display:none}

/* ORDER */
.order-group{margin-top:8px}
.order-header{display:flex;align-items:center;gap:6px;padding:5px 4px;font-size:11px;color:var(--muted);cursor:pointer;user-select:none;border-bottom:1px solid var(--border);margin-bottom:4px}
.order-name{font-family:var(--font-h);font-weight:700;font-size:11px;color:var(--text)}
.order-sci{font-style:italic;font-size:10px;color:var(--muted)}
.order-count{margin-left:auto;font-size:10px;background:var(--faint);border:1px solid var(--border);padding:0 6px;border-radius:6px}
.order-toggle{font-size:10px;color:var(--muted);transition:transform .2s}
.order-group.collapsed .order-toggle{transform:rotate(-90deg)}
.order-group.collapsed .order-species{display:none}
.order-species{display:flex;flex-direction:column;gap:3px;margin-top:2px}

/* SPECIES PILL */
.sp-pill{display:flex;align-items:center;gap:8px;padding:5px 8px;border-radius:7px;cursor:pointer;transition:background .15s}
.sp-pill:hover{background:rgba(255,255,255,.06)}
.sp-thumb{width:32px;height:32px;border-radius:5px;object-fit:cover;flex-shrink:0;background:rgba(0,0,0,.4);border:1px solid var(--border)}
.sp-names{flex:1;min-width:0}
.sp-common{font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.sp-sci{font-style:italic;font-size:10px;color:var(--muted)}
.sp-badge{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;padding:1px 7px;border-radius:6px;flex-shrink:0}
.badge-monocot{background:rgba(240,192,90,.18);color:var(--gold);border:1px solid rgba(240,192,90,.3)}
.badge-dicot{background:rgba(61,184,99,.14);color:var(--green);border:1px solid rgba(61,184,99,.25)}

/* COLOUR ACCENTS */
.k-animalia{border-color:rgba(86,196,232,.25)}.k-animalia .kingdom-header{background:linear-gradient(135deg,rgba(86,196,232,.06),transparent)}
.k-plantae{border-color:rgba(61,184,99,.25)}.k-plantae .kingdom-header{background:linear-gradient(135deg,rgba(61,184,99,.07),transparent)}
.k-fungi{border-color:rgba(176,126,232,.25)}.k-fungi .kingdom-header{background:linear-gradient(135deg,rgba(176,126,232,.08),transparent)}

/* EMPTY */
.empty-state{text-align:center;padding:60px 20px;color:var(--muted);display:none}
.empty-state.visible{display:block}
.empty-icon{font-size:3rem;margin-bottom:12px;opacity:.4}
</style>
</head>
<body>

<div class="topbar">
  <button class="back-btn" onclick="history.back()">← Encyclopedie</button>
  <div><div class="topbar-title">🌳 Fylogenetische boom</div><div class="topbar-sub">Belgische Fauna &amp; Flora — evolutionaire verwantschappen</div></div>
  <div class="isolate-notice" id="isolate-notice">
    <span>Gefilterd op branch</span>
    <button class="reset-btn" id="reset-isolate">Alles tonen ×</button>
  </div>
</div>

<div class="filter-bar">
  <span class="filter-label">Toon</span>
  <button class="filt-btn active" data-cat="all">🌍 Alles</button>
  <button class="filt-btn" data-cat="fauna">🦊 Zoogdieren</button>
  <button class="filt-btn" data-cat="birds">🐦 Vogels</button>
