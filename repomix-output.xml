<script src="js/data/species_data.js"></script>
<script>
const ALL = window.speciesData || [];
const FI = {};
ALL.forEach(sp => { const f=sp.family||'Unknown'; if(!FI[f]) FI[f]=[]; FI[f].push(sp); });

let G='all', Q='';
const GCATS={all:null,fauna:['fauna'],birds:['birds'],insects:['insects'],flora:['flora'],fungi:['fungi'],trees:['trees'],agriculture:['agriculture']};

function spMatch(sp){
  const cats=GCATS[G]; if(cats&&!cats.includes(sp.category)) return false;
  if(Q){ const n=sp.name?(typeof sp.name==='object'?(sp.name.nl||sp.name.en||''):sp.name):sp.scientific; return n.toLowerCase().includes(Q)||sp.scientific.toLowerCase().includes(Q); }
  return true;
}
function getName(sp){ const n=sp.name; if(!n) return sp.scientific; return typeof n==='object'?(n.nl||n.en||sp.scientific):n; }
function countUnder(node){
  let c=0;
  (node.families||[]).forEach(f=>(FI[f]||[]).forEach(sp=>{if(spMatch(sp))c++;}));
  (node.children||[]).forEach(ch=>{c+=countUnder(ch);});
  return c;
}
function collectCats(node){
  let cats=[...(node.cats||[])];
  (node.children||[]).forEach(c=>cats.push(...collectCats(c)));
  (node.families||[]).forEach(f=>(FI[f]||[]).forEach(sp=>{if(sp.category)cats.push(sp.category);}));
  return [...new Set(cats)];
}

const TREE=[
  {id:'animalia',icon:'🐾',label:'Dieren',sci:'Animalia',color:'#3db863',children:[
    {id:'mammalia',icon:'🦊',label:'Zoogdieren',sci:'Mammalia',color:'#3db863',cats:['fauna'],children:[
      {id:'carnivora',icon:'🦊',label:'Vleeseters',sci:'Carnivora',color:'#3db863',families:['Canidae','Felidae','Mustelidae','Phocidae','Phocoenidae']},
      {id:'rodentia',icon:'🐿️',label:'Knaagdieren',sci:'Rodentia',color:'#5ec87a',families:['Sciuridae','Muridae','Cricetidae','Castoridae']},
      {id:'lagomorpha',icon:'🐇',label:'Haasachtigen',sci:'Lagomorpha',color:'#5ec87a',families:['Leporidae']},
