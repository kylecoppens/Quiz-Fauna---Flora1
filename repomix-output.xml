function buildFam(fam,depth){
  const sps=(FI[fam]||[]).filter(spMatch); if(!sps.length) return null;
  const li=document.createElement('li'); li.className='ci';
  const fr=document.createElement('div'); fr.className='frow';
  fr.style.paddingLeft=`${depth*18+28}px`;
  fr.innerHTML=`<span class="flabel">${fam}</span><span class="fcnt">${sps.length}</span>`;
  li.appendChild(fr);
  const ul=document.createElement('ul'); ul.className='children clade';
  sps.forEach(sp=>{
    const sli=document.createElement('li'); sli.className='ci';
    const row=document.createElement('div'); row.className='sprow';
    row.style.paddingLeft=`${depth*18+38}px`;
    const g=sp.plantGrade;
    row.innerHTML=`<img class="spthumb" src="${sp.image||''}" alt="" loading="lazy" onerror="this.style.opacity='0.15'">
      <div class="spinfo"><div class="spname">${getName(sp)}</div><div class="spsci">${sp.scientific}</div></div>
      ${g?`<span class="spbadge b-${g==='monocot'?'mono':'dico'}">${g==='monocot'?'Monocot':'Dicot'}</span>`:''}`;
    sli.appendChild(row); ul.appendChild(sli);
  });
  li.appendChild(ul); return li;
}

function buildNode(node,depth){
  const cnt=countUnder(node); if(!cnt) return null;
  const li=document.createElement('li'); li.className='ci';
  const hasKids=(node.children||[]).length||(node.families||[]).length;
  const row=document.createElement('div'); row.className='nrow';
  row.style.paddingLeft=`${depth*18}px`;
  const col=node.color||'#aaa';
  row.innerHTML=`${hasKids?`<button class="tog" onclick="event.stopPropagation();(function(b){b.closest('.ci').classList.toggle('collapsed');b.textContent=b.closest('.ci').classList.contains('collapsed')?'+':'-'})(this)">-</button>`:`<div class="tog-sp"></div>`}
    <span class="nicon">${node.icon||'•'}</span>
    <span class="nlabel" style="border-color:${col}">${node.label}</span>
    <span class="nsci">${node.sci}</span>
    <span class="ncnt">${cnt}</span>`;
  li.appendChild(row);
  if(hasKids){
    const ul=document.createElement('ul'); ul.className='children clade';
    (node.families||[]).forEach(f=>{const x=buildFam(f,depth+1);if(x)ul.appendChild(x);});
    (node.children||[]).forEach(c=>{const x=buildNode(c,depth+1);if(x)ul.appendChild(x);});
    if(ul.children.length) li.appendChild(ul);
  }
  return li;
}

function render(){
  const wrap=document.getElementById('tree');
  const empty=document.getElementById('empty');
  if(!wrap) return;
  wrap.innerHTML='';
  if(empty){wrap.appendChild(empty);empty.style.display='none';}
  const ul=document.createElement('ul'); ul.className='clade';
  let total=0;
  TREE.forEach(top=>{
    const cnt=countUnder(top); if(!cnt) return;
    total+=cnt;
    const el=buildNode(top,0); if(!el) return;
    // Dim branches that contain none of the filtered category
    if(G!=='all'&&!Q){
      const cats=GCATS[G];
      const bc=collectCats(top);
      if(!bc.some(c=>cats.includes(c))) el.classList.add('dim');
    }
    ul.appendChild(el);
  });
  if(!total&&empty){empty.style.display='flex';}else{wrap.appendChild(ul);}
  const sc=document.getElementById('sp-count');
  if(sc) sc.innerHTML=`<b>${total}</b> soorten`;
  // Auto-expand when filtering
  if(G!=='all'||Q){
    wrap.querySelectorAll('.ci.collapsed').forEach(el=>{
      el.classList.remove('collapsed');
      const btn=el.querySelector(':scope > .nrow > .tog');
      if(btn) btn.textContent='-';
    });
  }
}

document.querySelectorAll('.chip').forEach(c=>{
  c.addEventListener('click',()=>{
    document.querySelectorAll('.chip').forEach(x=>x.classList.remove('active'));
    c.classList.add('active');
    G=c.dataset.g;
    render();
  });
});
document.getElementById('search').addEventListener('input',e=>{
  Q=e.target.value.trim().toLowerCase();
  render();
});

render();
</script>
